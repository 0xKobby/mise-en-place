# ========================
# MISE EN PLACE — .gitignore
# Vite + React + Node.js
# ========================


# ───────────────────────────────────────────
# ENVIRONMENT VARIABLES
# Never commit real API keys or secrets.
# Use .env.example as the safe, committed template.
# ───────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local


# ───────────────────────────────────────────
# DEPENDENCIES
# The node_modules folder is regenerated from
# package.json via `npm install` — no need to
# track it in version control.
# ───────────────────────────────────────────
node_modules/


# ───────────────────────────────────────────
# BUILD OUTPUT
# Vite writes the production bundle to /dist.
# vite-plugin-pwa also generates the Service
# Worker and manifest here at build time.
# ───────────────────────────────────────────
dist/
dist-ssr/


# ───────────────────────────────────────────
# VITE CACHE
# Vite's internal dependency pre-bundling cache.
# Safe to delete; rebuilt automatically on next
# `npm run dev`.
# ───────────────────────────────────────────
.vite/


# ───────────────────────────────────────────
# PWA GENERATED FILES
# These are auto-generated by vite-plugin-pwa
# during the build step — not hand-authored.
# ───────────────────────────────────────────
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map


# ───────────────────────────────────────────
# LOGS
# Runtime logs from Node and npm. Useful
# locally for debugging but not for the repo.
# ───────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ───────────────────────────────────────────
# OS & EDITOR ARTIFACTS
# Files generated by your operating system or
# code editor — not part of the project itself.
# ───────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
Session.vim


# ───────────────────────────────────────────
# TESTING
# Coverage reports are generated on demand —
# no need to track them in the repo.
# ───────────────────────────────────────────
coverage/
.nyc_output/


# ───────────────────────────────────────────
# MISC
# ───────────────────────────────────────────

# TypeScript build info (if TS is added later)
*.tsbuildinfo

# Optional: local Vercel CLI config
.vercel
